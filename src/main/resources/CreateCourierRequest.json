{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "definitions": {
    "CreateCourierDto": {
      "type": "object",
      "properties": {
        "courier_type": {
          "type": "string",
          "enum": [
            "FOOT",
            "BIKE",
            "AUTO"
          ]
        },
        "regions": {
          "type": "array",
          "items": {
            "type": "integer",
            "format": "int32"
          }
        },
        "working_hours": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9]-([0-1]?[0-9]|2[0-3]):[0-5][0-9]$"
          }
        }
      },
      "required": [
        "courier_type",
        "regions",
        "working_hours"
      ]
    }
  },
  "CreateCourierRequest": {
    "type": "object",
    "properties": {
      "couriers": {
        "type": "array",
        "items": {
          "$ref": "classpath:/CreateCourierRequest.json#/definitions/CreateCourierDto"
        }
      }
    },
    "required": [
      "couriers"
    ]
  }
}