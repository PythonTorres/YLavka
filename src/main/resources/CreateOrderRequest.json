{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "definitions": {
    "CreateOrderDto": {
      "required": [
        "cost",
        "delivery_hours",
        "regions",
        "weight"
      ],
      "type": "object",
      "properties": {
        "weight": {
          "type": "number",
          "format": "float",
          "minimum": 0
        },
        "regions": {
          "type": "integer",
          "format": "int32"
        },
        "delivery_hours": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9]-([0-1]?[0-9]|2[0-3]):[0-5][0-9]$"
          }
        },
        "cost": {
          "type": "integer",
          "format": "int32",
          "minimum": 0
        }
      }
    }
  },
  "CreateOrderRequest": {
    "required": [
      "orders"
    ],
    "type": "object",
    "properties": {
      "orders": {
        "type": "array",
        "items": {
          "$ref": "classpath:/CreateOrderRequest.json#/definitions/CreateOrderDto"
        }
      }
    }
  }
}